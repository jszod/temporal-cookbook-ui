# Temporal AI Cookbook UI - Environment Variables
# Copy this file to .env and fill in your actual API keys
# 
# Note: .env files are gitignored - never commit your actual .env file!

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# These keys are used by the Python worker (LiteLLM) to make API calls.
# You only need to set the keys for providers you want to use.

# OpenAI API Key
# Required for: OpenAI provider (gpt-4, gpt-3.5-turbo, etc.)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key
# Required for: Anthropic provider (claude-3-opus, claude-3-sonnet, etc.)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Groq API Key
# Required for: Groq provider (groq/llama-3-70b, groq/mixtral-8x7b, etc.)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Ollama Configuration (Optional)
# Required for: Ollama provider (local models)
# Defaults to http://localhost:11434 if not set
# Only needed if you want to use local Ollama models
OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# Temporal Configuration (Future)
# =============================================================================
# These may be needed for Temporal client configuration in future features
# TEMPORAL_ADDRESS=localhost:7233
# TEMPORAL_NAMESPACE=default
